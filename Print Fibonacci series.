import java.util.*;

public class Main{
    public static void main(String...args){
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();
        
        int a=0, b=1;

        System.out.print(a + " "+ b + " ");

        for(int i=3; i<=n; i++){
            
            int t = a+b;
            a = b;
            b = t;

            System.out.print(t+" ");
        }

    }
}
