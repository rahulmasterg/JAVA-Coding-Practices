import java.util.*;

public class Main{
    public static void main(String...args){
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();
        int k = sc.nextInt();
        int[] arr = new int[n];
        
        for(int i = 0; i < n; i++){
            arr[i] = sc.nextInt();
        }

        int res = binarySearch(arr, k, n);

        System.out.println("Searched Index: " + res);

        sc.close();;

    }

    static int binarySearch(int[] arr, int k, int n){
        
        int mid = -1;
        int l = 0, r = n-1;
        
        while (l<=r) {
            mid = l + (r-l)/2;
            
            if(arr[mid] == k){
                return mid;
            }else if(arr[mid]>k){
                r = mid - 1;
            }else{
                l = mid + 1;
            }
        }

        return mid;
    }
}
