import java.util.*;

public class Main{
    public static void main(String...args){
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();
        int t = n;
        
        int rev = 0;

        while(n != 0){
            rev = rev*10 + n%10;

            n /= 10;
        }

        if(t==rev)
            System.out.print(t+" is a Palindrome number");
        else
            System.out.print(t+" is not a Palindrome number");

    }
}
