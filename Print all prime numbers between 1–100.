import java.util.*;

public class Main{
    public static void main(String...args){
        Scanner sc = new Scanner(System.in);

        int i=2;

        while(i<=100){
            boolean f = false;
            for(int j=2; j<=i/2;  j++){
                if(i%j==0){
                    f = true;
                    break;
                }
            }
            if(!f){
                System.out.print(i+" ");
            }
            i++;
        }
    }
}
